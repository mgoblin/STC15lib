Import("env")

SConscript('ms_freq/SConscript', exports = 'env')

env.Command('uart.c', '#src/uart.c', Copy('$TARGET', '$SOURCE'))
env.Command('timer_ms_to_ticks.c', '#src/timer_ms_to_ticks.c', Copy('$TARGET', '$SOURCE'))
env.Command('timer_ticks_to_ms.c', '#src/timer_ticks_to_ms.c', Copy('$TARGET', '$SOURCE'))
env.Command('timer_ticks_to_Hz.c', '#src/timer_ticks_to_Hz.c', Copy('$TARGET', '$SOURCE'))
env.Command('timer_Hz_to_ticks.c', '#src/timer_Hz_to_ticks.c', Copy('$TARGET', '$SOURCE'))

env.Default(
    env.Program(
        'timer2_mode0_1T_interrupt_example',
        ['timer2_mode0_1T_interrupt_example.c']
    ),

    env.Program(
        'timer2_mode0_P30_output_example',
        ['timer2_mode0_P30_output_example.c']
    ),

    env.Program(
        'timer2_mode0_reload_example',
        ['timer2_mode0_reload_example.c']
    ),

    env.Program(
        'timer2_mode0_direct_reload_example',
        ['timer2_mode0_direct_reload_example.c']
    ),    

    env.Program(
        'timer2_mode0_ms_to_ticks_example',
        ['timer2_mode0_ms_to_ticks_example.c', 'uart.c', 'timer_ms_to_ticks.c']
    ),

    env.Program(
        'timer2_mode0_ticks_to_ms_example', 
        ['timer2_mode0_ticks_to_ms_example.c', 'uart.c', 'timer_ticks_to_ms.c']
    ),

    env.Program(
        'timer2_mode0_ticks_to_Hz_example',
        ['timer2_mode0_ticks_to_Hz_example.c', 'uart.c', 'timer_ticks_to_Hz.c']
    ),

    env.Program(
        'timer2_mode0_Hz_to_ticks_example',
        ['timer2_mode0_Hz_to_ticks_example.c', 'uart.c', 'timer_Hz_to_ticks.c']
    ),

)