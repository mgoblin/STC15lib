Import("env")

env.Command('uart.c', '#src/uart.c', Copy('$TARGET', '$SOURCE'))
env.Command('timer_to_ms_common.c', '#src/timer_to_ms_common.c', Copy('$TARGET', '$SOURCE'))

env.Default(
    env.Program(
        'timer0_common_example',
        ['timer0_common_example.c', 'uart.c']
    ),

    env.Program(
        'timer0_ms2ticks_example',
        ['timer0_ms2ticks_example.c', 'uart.c', 'timer_to_ms_common.c']
    ),

    env.Program(
        'timer2_common_example',
        ['timer2_common_example.c', 'uart.c']
    ),

)